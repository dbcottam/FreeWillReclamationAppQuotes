{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Will Reclamation Challenge Feed",
  "type": "object",
  "required": [
    "version",
    "lastUpdated",
    "allowedCategories",
    "challenges"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "contractVersion": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string"
    },
    "allowedCategories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "challenges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "challenge",
          "categories"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "challenge": {
            "type": "string"
          },
          "categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "scripture",
                "courage",
                "encouragement",
                "healing",
                "hope",
                "identity",
                "peace",
                "compassion",
                "perseverance",
                "purpose",
                "wisdom",
                "gratitude",
                "joy",
                "intuition",
                "boundaries",
                "embodiment",
                "surrender",
                "freedom",
                "discernment",
                "forgiveness",
                "agency",
                "abundance"
              ]
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
