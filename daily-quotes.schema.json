{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Will Reclamation Daily Quote Feed",
  "type": "object",
  "required": [
    "version",
    "lastUpdated",
    "quotes"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "contractVersion": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string"
    },
    "quotes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "day",
          "slug",
          "focus",
          "title",
          "artworkKey",
          "challenge",
          "prompt",
          "quote",
          "author",
          "source",
          "sourceUrl",
          "categories"
        ],
        "properties": {
          "day": {
            "type": "integer",
            "minimum": 1
          },
          "slug": {
            "type": "string"
          },
          "focus": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "artworkKey": {
            "type": "string"
          },
          "artworkUrl": {
            "type": "string"
          },
          "challenge": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "quote": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "sourceUrl": {
            "type": "string"
          },
          "categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "scripture",
                "courage",
                "encouragement",
                "healing",
                "hope",
                "identity",
                "peace",
                "perseverance",
                "purpose",
                "wisdom"
              ]
            }
          },
          "supplemental": {
            "type": "object",
            "required": [
              "url"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "youtube",
                  "podcast",
                  "article",
                  "resource",
                  "audio",
                  "video"
                ]
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "imageUrl": {
                "type": "string"
              },
              "durationLabel": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  }
}
