{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Will Reclamation Daily Journey Feed",
  "type": "object",
  "required": ["version", "lastUpdated", "quotes"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "lastUpdated": {
      "type": "string"
    },
    "quotes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "day",
          "quote",
          "author",
          "source",
          "sourceUrl",
          "categories"
        ],
        "properties": {
          "day": {
            "type": "integer",
            "minimum": 1
          },
          "slug": {
            "type": "string"
          },
          "focus": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "artworkKey": {
            "type": "string"
          },
          "challenge": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "celebrationPrompt": {
            "type": "string"
          },
          "quote": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "sourceUrl": {
            "type": "string"
          },
          "categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "scripture",
                "courage",
                "encouragement",
                "healing",
                "hope",
                "identity",
                "peace",
                "perseverance",
                "purpose",
                "wisdom"
              ]
            }
          }
        }
      }
    }
  }
}
