{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Will Reclamation Quote Feed",
  "type": "object",
  "required": [
    "version",
    "lastUpdated",
    "allowedCategories",
    "quotes"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "contractVersion": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string"
    },
    "allowedCategories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "scripture",
          "courage",
          "encouragement",
          "healing",
          "hope",
          "identity",
          "peace",
          "compassion",
          "perseverance",
          "purpose",
          "wisdom",
          "gratitude",
          "joy",
          "intuition",
          "boundaries",
          "embodiment",
          "surrender",
          "freedom",
          "discernment",
          "forgiveness",
          "agency",
          "abundance"
        ]
      }
    },
    "quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "quote",
          "author",
          "source",
          "sourceUrl",
          "categories"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "quote": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "sourceUrl": {
            "type": "string"
          },
          "categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "scripture",
                "courage",
                "encouragement",
                "healing",
                "hope",
                "identity",
                "peace",
                "compassion",
                "perseverance",
                "purpose",
                "wisdom",
                "gratitude",
                "joy",
                "intuition",
                "boundaries",
                "embodiment",
                "surrender",
                "freedom",
                "discernment",
                "forgiveness",
                "agency",
                "abundance"
              ]
            }
          }
        }
      }
    }
  }
}
