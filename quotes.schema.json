{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Will Reclamation Quote Feed",
  "type": "object",
  "required": [
    "version",
    "lastUpdated",
    "approvedCategories",
    "quotes"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "lastUpdated": {
      "type": "string"
    },
    "approvedCategories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "courage",
          "encouragement",
          "healing",
          "hope",
          "identity",
          "peace",
          "perseverance",
          "purpose",
          "wisdom"
        ]
      }
    },
    "quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "quote",
          "author",
          "source",
          "sourceUrl",
          "categories",
          "approved",
          "active"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "quote": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "sourceUrl": {
            "type": "string"
          },
          "categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "courage",
                "encouragement",
                "healing",
                "hope",
                "identity",
                "peace",
                "perseverance",
                "purpose",
                "wisdom"
              ]
            }
          },
          "approved": {
            "type": "boolean"
          },
          "active": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
